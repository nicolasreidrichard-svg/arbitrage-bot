# .env.example
# Copy this file to .env and fill in your values. Never commit .env to version control.

# ── RPC Endpoints ────────────────────────────────────────────────────────────
RPC_URL_1=https://rpc-url-1.com
RPC_URL_2=https://rpc-url-2.com

# ── DEX Routers ──────────────────────────────────────────────────────────────
DEX_ROUTER_1=0xRouterAddress1
DEX_ROUTER_2=0xRouterAddress2
UNISWAP_ROUTER_ADDRESS=0xE592427A0AEce92De3Edee1F18E0157C05861564
UNISWAP_SUBGRAPH_URL=https://api.thegraph.com/subgraphs/name/uniswap/uniswap-v3

# ── Wallet Configuration ─────────────────────────────────────────────────────
WALLET_ADDRESS=0xYourWalletAddress
WALLET_PRIVATE_KEY=your-private-key

# ── Chain-Specific Addresses ─────────────────────────────────────────────────
ETH_ADDRESS=0x08143f357d31Ec0D38B40eB383fC3450410c5CC7
SOL_ADDRESS=D1DYRrJqfuTnuTszWtv3nHChCcanGm7Q1eF2GUUQ2r3
ETH_PROFIT_DESTINATION=0x08143f357d31Ec0D38B40eB383fC3450410c5CC7
SOL_PROFIT_DESTINATION=D1DYRrJqfuTnuTszWtv3nHChCcanGm7Q1eF2GUUQ2r3

# ── Blockchain API Keys ───────────────────────────────────────────────────────
# Etherscan: https://etherscan.io/myapikey
ETHERSCAN_API_KEY=your-etherscan-api-key
# Solscan Pro: https://pro.solscan.io/
SOLSCAN_API_KEY=your-solscan-api-key
# Helius (Solana RPC + priority fees): https://www.helius.dev/
HELIUS_API_KEY=your-helius-api-key

# ── Exchange API Keys ─────────────────────────────────────────────────────────
# Binance: https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=your-binance-api-key
BINANCE_API_SECRET=your-binance-api-secret
BINANCE_MAX_ORDER_USD=10000

# Coinbase Advanced Trade: https://www.coinbase.com/settings/api
COINBASE_API_KEY=your-coinbase-api-key
COINBASE_API_SECRET=your-coinbase-api-secret
COINBASE_PASSPHRASE=your-coinbase-passphrase
COINBASE_MAX_ORDER_USD=10000

# ── Monitoring Settings ───────────────────────────────────────────────────────
MONITORING_INTERVAL=5000
ALERT_EMAIL=youremail@example.com

# ── Profit & Gas Settings ─────────────────────────────────────────────────────
# Minimum profit (ETH) before auto-routing to destination wallet
PROFIT_THRESHOLD_ETH=0.001
# Minimum profit (SOL) before auto-routing to destination wallet
PROFIT_THRESHOLD_SOL=0.01
# Set to 'true' to enable automatic profit routing after each trade
AUTO_ROUTE_PROFITS=false
# Gas priority for ETH transactions: slow | standard | fast
ETH_GAS_PRIORITY=standard
DEFAULT_GAS_PRICE_GWEI=20
SOL_COMPUTE_UNITS=200000

# ── Earnings Reporting ────────────────────────────────────────────────────────
EARNINGS_REPORTING_ENABLED=true
# Report generation interval in milliseconds (default: 1 hour)
EARNINGS_REPORT_INTERVAL_MS=3600000
# Output format: text | json
EARNINGS_REPORT_FORMAT=text

# ── Legacy API Configuration ──────────────────────────────────────────────────
API_KEY=your-api-key
API_SECRET=your-api-secret